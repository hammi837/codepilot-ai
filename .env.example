# ── App ───────────────────────────────────────────────────────────────────
PROJECT_NAME=CodePilot AI
VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/codepilot
# Or use individual parts:
# DB_HOST=localhost
# DB_PORT=5433
# DB_NAME=codepilot
# DB_USER=postgres
# DB_PASSWORD=postgres

# ── Security ──────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── GitHub OAuth ──────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:8000/api/v1/github/callback

# ── LLM Providers (choose one) ────────────────────────────────────────────
# Option 1: Groq (fast, free tier available)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Option 2: xAI / Grok
# XAI_API_KEY=your_xai_api_key
# XAI_MODEL=grok-4
# XAI_BASE_URL=https://api.x.ai/v1

# Option 3: OpenAI
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_API_BASE=https://api.openai.com/v1

# ── Embeddings ────────────────────────────────────────────────────────────
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=200

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379